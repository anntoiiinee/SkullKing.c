    "COMPONENTS.md",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc && npm run copy-fonts && npm run move-types",
    "copy-fonts": "node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync('dist/fonts',{recursive:true});fs.readdirSync('src/fonts').filter(f=>f.endsWith('.woff2')).forEach(f=>fs.copyFileSync(p.join('src/fonts',f),p.join('dist/fonts',f)))\"",
    "move-types": "mv dist/components/*.d.ts dist/ && mv dist/components/backgrounds/*.d.ts dist/backgrounds/ && rm -rf dist/components dist/lib dist/types",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify-build.mjs"
  },
